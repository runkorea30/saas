# ============================================================
# Supabase 연결 정보
# ============================================================
# 실제 값은 .env 파일에 입력 (이 파일은 예시/커밋용)
# Supabase Dashboard > Project Settings > API 에서 복사

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# ============================================================
# Anthropic Claude API — 인보이스 PDF 자동 파싱 (수입/매입 페이지)
# ============================================================
# 🔴 VITE_ 접두사 없음 — Vercel Serverless 함수(api/analyze-invoice.ts) 전용.
#    클라이언트 번들에는 절대 포함되지 않음.
# 로컬 개발: .env.local 에 이 이름 그대로 등록 + `npx vercel dev` 로 실행해야 /api/* 라우팅 동작.
# 배포: Vercel 프로젝트 Settings > Environment Variables 에 서버 전용으로 등록.
# 키 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ============================================================
# Toss Payments (Phase 5에서 사용)
# ============================================================
# VITE_TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=         # Edge Function에서만 사용

# ============================================================
# 슈퍼 관리자 (선택)
# ============================================================
# VITE_SUPER_ADMIN_ENABLED=false

# ============================================================
# 데이터 이관 스크립트 (scripts/migrate_dogfooding_data.py)
# ============================================================
# Supabase Dashboard > Project Settings > Database > Connection String (Pooler, port 6543)
# 실제 비밀번호는 .env 에만 입력. 여기는 placeholder.
# 비밀번호에 @, #, : 가 포함되면 URL-encoding 필수.
SOURCE_DB_URL=postgresql://postgres.hhgicytfzmikuavgbgov:<PASSWORD>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
TARGET_DB_URL=postgresql://postgres.adfobvwuzkufsmukdfrt:<PASSWORD>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
